        <allowPause>false</allowPause>
        <fields>
            <name>txt_error_proposal</name>
            <fieldText>&lt;p&gt;⚠️ &lt;strong&gt;Cơ hội này yêu cầu Technical Proposal nhưng chưa có Proposal nào.&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Vui lòng tạo ít nhất &lt;strong&gt;1 Proposal&lt;/strong&gt; trước khi gửi cho khách hàng.&lt;/p&gt;</fieldText>
