            <fieldText>&lt;p&gt;Bạn có chắc chắn muốn gửi hồ sơ thầu cho khách hàng không?&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
